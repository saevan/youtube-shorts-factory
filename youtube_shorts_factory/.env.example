# ============================================================
# .env.example — Salin file ini menjadi .env lalu isi nilainya
# ============================================================

# === GEMINI API ===
# Dapatkan di: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === DEEPSEEK API ===
# Dapatkan di: https://platform.deepseek.com/api-keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === YOUTUBE DATA API v3 (Opsional — tidak digunakan untuk upload) ===
# Upload via Selenium (browser automation), bukan via API.
# File dibawah hanya sebagai referensi.
# YOUTUBE_CLIENT_SECRET_FILE=credentials/client_secret.json
# YOUTUBE_TOKEN_FILE=credentials/youtube_token.json

# === KONFIGURASI VIDEO (Opsional, ada default di config.py) ===
# Jadwal upload (WIB) — format 24 jam, pisahkan dengan koma
SCHEDULE_TIMES=08:00,13:00,19:00

# Jumlah video background yang akan didownload per sesi
BG_VIDEO_POOL_SIZE=10

# ============================================================
# RAILWAY DEPLOYMENT NOTES:
# ============================================================
# Di Railway, set environment variables di Dashboard Railway:
# - GEMINI_API_KEY
# - DEEPSEEK_API_KEY
# - SCHEDULE_TIMES
# - BG_VIDEO_POOL_SIZE
# - TZ=Asia/Jakarta (timezone)
#
# chrome_profile/ akan dibuat otomatis. Login YouTube pertama
# kali dilakukan via Railway Shell: 
#   python railway_setup.py --login
